 331:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** static void prvRestoreContextOfFirstTask( void )
 332:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** {
 333:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 	__asm volatile
 334:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 	(
 335:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r0, =0xE000ED08				\n" /* Use the NVIC offset register to locate the stack. */
 336:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r0, [r0]					\n"
 337:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r0, [r0]					\n"
 338:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	msr msp, r0						\n" /* Set the msp back to the start of the stack. */
 339:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr	r3, pxCurrentTCBConst2		\n" /* Restore the context. */
 340:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r1, [r3]					\n"
 341:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r0, [r1]					\n" /* The first item in the TCB is the task top of stack. */
 342:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	add r1, r1, #4					\n" /* Move onto the second item in the TCB... */
 343:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"									\n"
 344:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	dmb								\n" /* Complete outstanding transfers before disabling MPU. */
 345:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r2, =0xe000ed94				\n" /* MPU_CTRL register. */
 346:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r3, [r2]					\n" /* Read the value of MPU_CTRL. */
 347:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	bic r3, #1						\n" /* r3 = r3 & ~1 i.e. Clear the bit 0 in r3. */
 348:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	str r3, [r2]					\n" /* Disable MPU. */
 349:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"									\n"
 350:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r2, =0xe000ed9c				\n" /* Region Base Address register. */
 351:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldmia r1!, {r4-r11}				\n" /* Read 4 sets of MPU registers from TCB. */
 352:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	stmia r2!, {r4-r11}				\n" /* Write 4 sets of MPU registers. */
 353:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"									\n"
 354:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r2, =0xe000ed94				\n" /* MPU_CTRL register. */
 355:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldr r3, [r2]					\n" /* Read the value of MPU_CTRL. */
 356:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	orr r3, #1						\n" /* r3 = r3 | 1 i.e. Set the bit 0 in r3. */
 357:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	str r3, [r2]					\n" /* Enable MPU. */
 358:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	dsb								\n" /* Force memory writes before continuing. */
 359:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"									\n"
 360:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	ldmia r0!, {r3-r11, r14}		\n" /* Pop the registers that are not automatically saved on exceptio
 361:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	msr control, r3					\n"
 362:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	msr psp, r0						\n" /* Restore the task stack pointer. */
 363:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	mov r0, #0						\n"
 364:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	msr	basepri, r0					\n"
 365:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	bx r14							\n"
 366:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"									\n"
 367:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"	.align 4						\n"
 368:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 		"pxCurrentTCBConst2: .word pxCurrentTCB	\n"
 369:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** 	);
 370:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** }
 371:Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4_MPU/port.c **** /*-----------------------------------------------------------*/
